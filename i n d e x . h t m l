<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Penguin AI Global</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--black:#03050f;--deep:#060c1e;--panel:#0a1228;--border:#1a2d5a;--cyan:#00d4ff;--cyan-dim:#0088bb;--violet:#7b3fe4;--white:#e8f4ff;--muted:#6a84aa}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:'Inter',sans-serif;overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 6vw;height:68px;background:rgba(3,5,15,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.logo{font-family:'Orbitron',monospace;font-weight:900;font-size:1.1rem;text-decoration:none;color:var(--white);display:flex;align-items:center;gap:10px}
.logo span{color:var(--cyan)}
.logo-icon{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--violet));display:flex;align-items:center;justify-content:center;font-size:1.2rem}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s}
.nav-links a:hover{color:var(--cyan)}
.nav-cta{background:transparent;border:1.5px solid var(--cyan);color:var(--cyan);padding:.5rem 1.3rem;border-radius:6px;font-family:'Orbitron',monospace;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-decoration:none}
.hero{min-height:100vh;display:flex;align-items:center;padding:100px 6vw 60px;position:relative;overflow:hidden;background:radial-gradient(ellipse at 60% 50%,rgba(123,63,228,.2) 0%,transparent 60%),radial-gradient(ellipse at 20% 80%,rgba(0,212,255,.1) 0%,transparent 50%)}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,212,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.04) 1px,transparent 1px);background-size:60px 60px;animation:grid 20s linear infinite}
@keyframes grid{from{background-position:0 0}to{background-position:0 60px}}
.hero-inner{position:relative;z-index:1;max-width:800px;margin:0 auto;width:100%}
.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.25);border-radius:100px;padding:.35rem 1rem;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);font-weight:600;margin-bottom:1.5rem}
.badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--cyan);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
h1{font-family:'Orbitron',monospace;font-size:clamp(2.8rem,6vw,5rem);font-weight:900;line-height:1.05;margin-bottom:1.2rem}
h1 .accent{color:var(--cyan)}
.sub{font-size:1.1rem;color:var(--muted);max-width:560px;margin-bottom:2.5rem;line-height:1.7}
.features{display:flex;gap:1.5rem;margin-bottom:2.5rem;flex-wrap:wrap}
.feat{font-size:.78rem;color:var(--cyan);letter-spacing:.08
em;text-transform:uppercase;font-weight:600}
.actions{display:flex;gap:1rem;flex-wrap:wrap}
.btn-p{background:linear-gradient(135deg,var(--violet),var(--cyan-dim));color:#fff;border:none;padding:.85rem 2rem;border-radius:8px;font-family:'Orbitron',monospace;font-size:.78rem;font-weight:700;letter-spacing:.1em;cursor:pointer;box-shadow:0 0 30px rgba(123,63,228,.4);transition:transform .15s;text-decoration:none;display:inline-block}
.btn-p:hover{transform:translateY(-2px)}
.btn-s{background:transparent;border:1.5px solid var(--border);color:var(--white);padding:.85rem 1.8rem;border-radius:8px;font-family:'Orbitron',monospace;font-size:.78rem;font-weight:600;letter-spacing:.1em;text-decoration:none;display:inline-block;transition:border-color .2s}
.btn-s:hover{border-color:var(--cyan-dim);color:var(--cyan)}
section{padding:90px 6vw}
.inner{max-width:1100px;margin:0 auto}
.ey{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--cyan);font-weight:700;margin-bottom:.75rem}
h2{font-family:'Orbitron',monospace;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:700;margin-bottom:1rem}
.dsc{color:var(--muted);max-width:520px;line-height:1.75;margin-bottom:3rem}
.grid4{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5px;background:var(--border);border:1.5px solid var(--border);border-radius:16px;overflow:hidden}
.phase{background:var(--deep);padding:2rem 1.6rem;transition:background .2s}
.phase:hover{background:var(--panel)}
.pnum{font-family:'Orbitron',monospace;font-size:.65rem;letter-spacing:.18em;color:var(--cyan);font-weight:700;margin-bottom:.5rem;opacity:.7}
.ptitle{font-family:'Orbitron',monospace;font-size:.95rem;font-weight:700;margin-bottom:1.2rem}
.picon{font-size:1.6rem;margin-bottom:.8rem;display:block}
ul.pi{list-style:none}
ul.pi li{font-size:.84rem;color:var(--muted);padding:.35rem 0;border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:.6rem}
ul.pi li::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--cyan);flex-shrink:0;opacity:.7}
ul.pi li:last-child{border-bottom:none}
.ag{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:2rem}
.ac{background:var(--panel);padding:2rem 1.5rem;text-align:center}
.ai{font-size:2rem;margin-bottom:.7rem}
.an{font-family:'Orbitron',monospace;font-size:.78rem;font-weight:700;color:var(--cyan);margin-bottom:.5rem;letter-spacing:.06em}
.ad{font-size:.82rem;color:var(--muted);line-height:1.6}
.cbox{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.cbox code{font-family:'Inter',monospace;font-size:.8rem;color:var(--cyan);word-break:break-all}
.cpbig{background:var(--cyan);color:var(--black);border:none;border-radius:7px;padding:.6rem 1.3rem;font-family:'Orbitron',monospace;font-size:.7rem;font-weight:700;letter-spacing:.08em;cursor:pointer;white-space:nowrap;flex-shrink:0}
footer{padding:50px 6vw 30px;border-top:1px solid var(--border)}
.fi{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem}
.fb{font-family:'Orbitron',monospace;font-weight:900}
.fb span{color:var(--cyan)}
.ft{font-size:.8rem;color:var(--muted);margin-top:.3rem}
.fc{width:100%;font-size:.72rem;color:var(--muted);border-top:1px solid rgba(255,255,255,.05);padding-top:1.2rem;margin-top:.5rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:.5rem}
.xl{color:var(--muted);text-decoration:none;font-size:.85rem;display:flex;align-items:center;gap:.4rem;transition:color .2s}
.xl:hover{color:var(--cyan)}
@media(max-width:768px){.nav-links{display:none}}
</style>
</head>
